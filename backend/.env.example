PORT=8080
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here
DB_PATH=./data/librarian.db

# Optional qBittorrent Web UI connection. Configure this in Settings for
# multi-instance support, or use these variables as a power-user override.
# Username/password may be blank only when qBittorrent's authentication bypass
# trusts the Plex Librarian host or subnet.
# QBITTORRENT_URL=http://localhost:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your_qbittorrent_password

# Optional: sync concurrency tuning. Defaults (shown below) are deliberately
# conservative to keep the footprint small — only raise these on dedicated
# hardware with room to spare.
# LIBRARY_SYNC_CONCURRENCY=3
# FETCH_CONCURRENCY=8

# Optional: abort a sync that reports no progress for this many minutes (e.g. the
# Plex host went offline mid-sync and a connection is hanging instead of erroring).
# SYNC_STALL_TIMEOUT_MINUTES=15

# Optional: how many days of sync history and activity feed entries to keep before
# they're automatically deleted. Raise this if you want to retain history longer,
# or set to 0 to keep them forever.
# LOG_RETENTION_DAYS=180

# Sonarr and Radarr instances are configured and mapped to libraries from the
# Settings page. Their API keys are stored in this database; there are no Arr
# environment variables so multiple instances can be configured independently.
