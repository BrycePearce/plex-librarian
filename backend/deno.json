{
  "name": "backend",
  "exports": {},
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --allow-ffi --env-file=.env src/server.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --env-file=.env src/server.ts",
    "db:generate": "deno run -A --env-file=.env drizzle-kit generate",
    "db:migrate": "deno run --allow-read --allow-write --allow-env --allow-ffi --allow-net --env-file=.env src/db/migrate.ts",
    "db:reset": "rm -f ./data/librarian.db ./data/librarian.db-shm ./data/librarian.db-wal && deno task db:migrate",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": true
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.12.31",
    "hono/logger": "jsr:@hono/hono@^4.12.31/logger",
    "hono/body-limit": "jsr:@hono/hono@^4.12.31/body-limit",
    "hono/deno": "jsr:@hono/hono@^4.12.31/deno",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/path": "jsr:@std/path@^1.1.6",
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "drizzle-orm/sqlite-proxy": "npm:drizzle-orm@^0.45.2/sqlite-proxy",
    "drizzle-orm/sqlite-core": "npm:drizzle-orm@^0.45.2/sqlite-core",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10"
  },
  "compilerOptions": {
    "strict": true
  }
}
